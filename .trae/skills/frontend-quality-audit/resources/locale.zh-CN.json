    "hygiene": {
      "category": "代码卫生",
      "summary": "代码库中存在调试残留和跳过检查现象。",
      "impact": "这类临时性处理会掩盖真实缺陷，削弱静态检查的可信度。",
      "recommendation": "清理调试语句，恢复被临时跳过的 lint 或类型检查，并把这些动作纳入合并前门禁。"
    },
    "maintainability": {
      "category": "可维护性",
      "summary": "重复导入和格式异常说明结构控制与清理纪律不足。",
      "impact": "重复模式会增加阅读负担，通常也意味着隐藏的重复逻辑没有被抽离。",
      "recommendation": "统一导入、提取重复逻辑，并通过 lint 或重构检查点控制文件体积与行复杂度。"
    },
    "tooling": {
      "category": "工具链",
      "summary": "工具链缺口会导致低质量代码无法被稳定识别。",
      "impact": "缺少 lint 和类型检查门禁时，劣化代码会持续累积，无用代码也更难被及时清理。",
      "recommendation": "统一 ESLint 和 TypeScript 检查方式，补齐 lint 与 typecheck 脚本，并纳入本地与 CI 流程。"
    },
    "mixedResponsibilities": {
      "category": "职责边界",
      "summary": "部分文件同时承担视图、状态、接口、类型或工具职责，存在明显的边界混杂。",
      "impact": "职责混杂会放大修改影响范围，让测试、重构和交接都变得困难。",
      "recommendation": "按页面入口、展示组件、hooks、services、types、constants、utils 等边界拆分，避免一个文件承载完整业务链路。"
    },
    "frameworkSpecific": {
      "category": "框架专项",
      "summary": "部分文件没有遵守前端框架中常见的职责边界约定。",
      "impact": "一旦页面、组件、hooks、services 或 store 的边界退化，重构成本会快速放大。",
      "recommendation": "把目录名称只作为辅助信号，更重要的是围绕视图、状态、接口、hooks、store 等职责边界建立专项规则。"
    }
  },
  "splitRecommendations": {
    "extractUiSections": "将页面中的大块 UI 区域拆成子组件，控制主文件只负责组装。",
    "extractHooks": "把状态管理、副作用和派生逻辑下沉到自定义 hooks，避免页面文件承担完整业务流程。",
    "extractServices": "把接口调用、请求组装和响应映射抽到 services 或 api 模块。",
    "extractTypes": "把 interface、type、枚举等声明迁移到独立 types 文件，降低主文件认知负担。",
    "extractConstants": "把常量、配置映射、选项列表抽到 constants 文件，减少页面噪音。",
    "extractUtils": "把格式化、过滤、转换等纯函数抽到 utils 或 helpers，避免页面内堆积工具逻辑。",
    "extractAnalysisPhases": "按职责拆分扫描、评分、报告组装等阶段，避免单个脚本承担完整审计流程。",
    "extractRenderPipeline": "把 Markdown 生成、HTML 生成和结果汇总拆成独立模块，降低输出层与分析层耦合。",
    "keepEntryLean": "保留一个精简的入口组件，只做布局拼装和依赖串联。"
  },
  "roadmap": {
    "p0": "先建立质量门禁，清理跳过检查与调试残留，冻结继续劣化。",
